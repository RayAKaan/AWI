{
  "name": "@awi-protocol/react",
  "version": "0.3.0",
  "description": "React hooks for AWI (Agent Web Interface)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "awi",
    "agent-web-interface",
    "react",
    "hooks",
    "ai-agent",
    "browser-automation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "dependencies": {
    "@awi-protocol/sdk": "workspace:*",
    "@awi-protocol/types": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}

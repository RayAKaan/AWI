{
  "name": "@awi-protocol/site-sdk",
  "version": "0.3.0",
  "description": "Build agent-native endpoints for your website",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "awi",
    "agent-web-interface",
    "site-sdk",
    "ai-agent",
    "browser-automation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@awi-protocol/types": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "express": "^4.18.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
